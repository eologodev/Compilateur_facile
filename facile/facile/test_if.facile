// test_if.facile
// Test instruction conditionnelle (exercices 4, 5, 6)

read x;

// Test simple (exercice 4)
if x > 0 then
    print x;
endif

// Test avec else (exercice 5)
if x >= 0 then
    print x;
else
    y := 0 - x;
    print y;
endif

// Test avec elseif (exercice 5)
if x < 0 then
    z := 0 - x;
    print z;
elseif x = 0 then
    print x;
else
    print x;
endif
