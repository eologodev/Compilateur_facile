// test_while.facile
// Test boucle while (exercices 7, 8, 9)

// Boucle simple : affiche 1 a 5
i := 1;
while i <= 5 do
    print i;
    i := i + 1;
endwhile
// Boucle avec break : affiche jusqu'a 3
j := 1;
while j <= 10 do
    if j > 3 then
        break;
    endif
    print j;
    j := j + 1;
endwhile
